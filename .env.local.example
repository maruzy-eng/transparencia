# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Admin auth (server-only — never expose to the client)
# Generate with: openssl rand -base64 32
ADMIN_AUTH_SECRET=

# Supabase service role (server-only — bypasses RLS for admin operations)
# Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Seed script only (not used by the Next.js app)
# ADMIN_SEED_EMAIL=diego.maruzy@gmail.com
# ADMIN_SEED_NAME=Diego Maruzy
# ADMIN_INITIAL_PASSWORD=
